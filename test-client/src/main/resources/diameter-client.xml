<?xml version="1.0"?>
<!--
  jdiameter Stack configuration — diameter-cc-test-client (PDN Gateway simulator).
  Initiates a TCP connection to the server. Uses server-schema XSD because the
  pure-client StackImpl does not expose the Network interface, which we need
  in order to call addNetworkReqListener and advertise App-Id 4 in the CER.
-->
<Configuration xmlns="http://www.jdiameter.org/jdiameter-server">

    <LocalPeer>
        <URI value="aaa://test-client.local:3869"/>
        <IPAddresses>
            <IPAddress value="0.0.0.0"/>
        </IPAddresses>
        <Realm value="pseonkyaw.dev"/>
        <VendorID value="10415"/>
        <ProductName value="diameter-cc-test-client"/>
        <FirmwareRevision value="1"/>
    </LocalPeer>

    <Parameters>
        <AcceptUndefinedPeer value="false"/>
        <DuplicateProtection value="true"/>
        <DuplicateTimer value="240000"/>
        <UseUriAsFqdn value="false"/>
        <QueueSize value="10000"/>
        <MessageTimeOut value="5000"/>
        <StopTimeOut value="10000"/>
        <CeaTimeOut value="10000"/>
        <IacTimeOut value="30000"/>
        <DwaTimeOut value="10000"/>
        <DpaTimeOut value="5000"/>
        <RecTimeOut value="10000"/>

        <Concurrent>
            <Entity name="ThreadGroup" size="16"/>
            <Entity name="ProcessingMessageTimer" size="1"/>
            <Entity name="DuplicationMessageTimer" size="1"/>
            <Entity name="RedirectMessageTimer" size="1"/>
            <Entity name="PeerOverloadTimer" size="1"/>
            <Entity name="ConnectionTimer" size="1"/>
            <Entity name="StatisticTimer" size="1"/>
        </Concurrent>
    </Parameters>

    <Network>
        <Peers>
            <Peer name="aaa://diameter-cc-server:3868"
                  attempt_connect="true"
                  rating="1"/>
        </Peers>
        <Realms>
            <Realm name="pseonkyaw.dev"
                   peers="diameter-cc-server"
                   local_action="LOCAL"
                   dynamic="false"
                   exp_time="1">
                <ApplicationID>
                    <VendorId value="0"/>
                    <AuthApplId value="4"/>
                    <AcctApplId value="0"/>
                </ApplicationID>
            </Realm>
        </Realms>
    </Network>

    <Extensions>
        <PeerFsmFactory value="org.jdiameter.server.impl.fsm.FsmFactoryImpl"/>
        <SessionFactory value="org.jdiameter.client.impl.SessionFactoryImpl"/>
    </Extensions>

</Configuration>
